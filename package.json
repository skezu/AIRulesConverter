{
  "name": "aimig",
  "displayName": "AI Migrate",
  "publisher": "skezu",
  "description": "Convert AI coding rules between Cursor, Windsurf, Kiro, Antigravity, Claude Code, Gemini CLI, and GitHub Copilot formats. Also available as a standalone CLI.",
  "icon": "images/logo.png",
  "version": "1.7.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skezu/RulesConverter.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "cursor",
    "windsurf",
    "kiro",
    "antigravity",
    "claude",
    "claude-code",
    "gemini",
    "gemini-cli",
    "copilot",
    "ai",
    "rules",
    "converter",
    "CLAUDE.md",
    "GEMINI.md",
    "ai-rules"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "bin": {
    "aimig": "./out/cli.js"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rules-converter-view",
          "title": "Rules Converter",
          "icon": "$(symbol-ruler)"
        }
      ]
    },
    "views": {
      "rules-converter-view": [
        {
          "id": "detected-rules",
          "name": "Detected Rules"
        }
      ]
    },
    "commands": [
      {
        "command": "rulesConverter.refresh",
        "title": "Refresh Rules",
        "icon": "$(refresh)"
      },
      {
        "command": "rulesConverter.convertRule",
        "title": "Convert",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "rulesConverter.convertAllRules",
        "title": "Convert All Rules",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "rulesConverter.openRule",
        "title": "Open Rule"
      },
      {
        "command": "rulesConverter.deleteRule",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "rulesConverter.migrateWorkspace",
        "title": "Migrate Workspace Capabilities",
        "icon": "$(sync)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rulesConverter.refresh",
          "when": "view == detected-rules",
          "group": "navigation"
        },
        {
          "command": "rulesConverter.migrateWorkspace",
          "when": "view == detected-rules",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "rulesConverter.convertRule",
          "when": "view == detected-rules && (viewItem == rule || viewItem == skill || viewItem == mcp)",
          "group": "inline"
        },
        {
          "command": "rulesConverter.convertAllRules",
          "when": "view == detected-rules && viewItem == virtual-folder",
          "group": "inline"
        },
        {
          "command": "rulesConverter.convertAllRules",
          "when": "view == detected-rules && viewItem == ide",
          "group": "inline"
        },
        {
          "command": "rulesConverter.deleteRule",
          "when": "view == detected-rules && (viewItem == rule || viewItem == skill || viewItem == mcp || viewItem == virtual-folder || viewItem == ide)",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run build",
    "build": "node esbuild.js",
    "package": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "cli": "node out/cli.js"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^16.x",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.27.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}